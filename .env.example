# DjangoPress Environment Variables
# Copy this file to .env and fill in the values

# ===== REQUIRED =====
SECRET_KEY=django-insecure-change-me-in-production

# Environment: 'development' or 'production'
ENVIRONMENT=development

# Debug mode override (independent of environment)
DEBUG_MODE=False

# ===== DATABASE =====
# SQLite (default — no config needed):
#   Uses db.sqlite3 in project root automatically
#
# PostgreSQL (for high-traffic sites):
#   DATABASE_URL=postgres://user:password@host:5432/dbname
#
# Railway provides DATABASE_URL automatically when you add a Postgres plugin.

# ===== AI PROVIDERS =====
# At least one is required for AI features. All load with graceful fallback.
# GEMINI_API_KEY=your-gemini-api-key
# OPENAI_API_KEY=your-openai-api-key
# ANTHROPIC_API_KEY=your-anthropic-api-key

# ===== EMAIL (Production) =====
# MAILGUN_API_KEY=your-mailgun-api-key
# MAILGUN_API_URL=https://api.eu.mailgun.net/v3
# DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# ===== GOOGLE CLOUD STORAGE (Production) =====
# GS_BUCKET_NAME=your-bucket-name
# GS_PROJECT_ID=your-project-id
# GCS_CREDENTIALS_JSON={"type": "service_account", ...}
# GS_CREDENTIALS_FILE_PATH=path/to/credentials.json

# ===== STOCK PHOTOS =====
# Unsplash: use the "Access Key" from your app's Keys page (not the Secret key)
# https://unsplash.com/oauth/applications
# UNSPLASH_ACCESS_KEY=your-access-key

# ===== DEBUGGING =====
# ENABLE_DEBUG_LOGGING=False
