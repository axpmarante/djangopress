# DjangoPress Environment Variables
# Copy this file to .env and fill in the values

# ===== REQUIRED =====
SECRET_KEY=django-insecure-change-me-in-production

# Environment: 'development' or 'production'
ENVIRONMENT=development

# Debug mode override (independent of environment)
DEBUG_MODE=False

# ===== DATABASE =====
# SQLite is used in all environments. Litestream replicates to GCS.
# No configuration needed — works out of the box.
# LITESTREAM_REPLICA_PATH=my-site/db/prod/

# ===== AI PROVIDERS =====
# At least one is required for AI features. All load with graceful fallback.
#
# Google Gemini — pick ONE:
#   Option A: Vertex AI (recommended — dedicated quotas, no rate limit 503s)
#   Requires: gcloud auth application-default login, Vertex AI API enabled
# VERTEX_AI_PROJECT=your-gcp-project-id
# VERTEX_AI_LOCATION=global
#
#   Option B: Public Gemini API (simpler setup, shared quotas)
# GEMINI_API_KEY=your-gemini-api-key
#
# OPENAI_API_KEY=your-openai-api-key
# ANTHROPIC_API_KEY=your-anthropic-api-key

# ===== EMAIL (Production) =====
# MAILGUN_API_KEY=your-mailgun-api-key
# MAILGUN_API_URL=https://api.eu.mailgun.net/v3
# DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# ===== GOOGLE CLOUD STORAGE (Production) =====
# GS_BUCKET_NAME=your-bucket-name
# GS_PROJECT_ID=your-project-id
# GCS_CREDENTIALS_JSON={"type": "service_account", ...}
# GS_CREDENTIALS_FILE_PATH=path/to/credentials.json

# ===== STOCK PHOTOS =====
# Unsplash: use the "Access Key" from your app's Keys page (not the Secret key)
# https://unsplash.com/oauth/applications
# UNSPLASH_ACCESS_KEY=your-access-key

# ===== DEBUGGING =====
# ENABLE_DEBUG_LOGGING=False
